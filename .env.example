# .env.example — template for local development
# Copy to .env and fill in the values (never commit .env)
# All vars use the ROLE_ prefix (Viper AutomaticEnv)

# MongoDB
ROLE_MONGO_URI=mongodb://admin:<password>@10.11.12.238:27017/role_organizado_dev?authSource=admin&replicaSet=rs0
ROLE_MONGO_DATABASE=role_organizado_dev

# JWT — must match the Java backend JWT_SECRET exactly (token interoperability)
ROLE_JWT_SECRET=<same-as-java-jwt-secret>

# Redis — dev LXC 305 (10.11.12.240)
ROLE_REDIS_ADDR=10.11.12.240:6379
ROLE_REDIS_PASSWORD=<redis-password>
ROLE_REDIS_DB=0

# Temporal — dev LXC (10.11.12.244)
ROLE_TEMPORAL_HOST_PORT=10.11.12.244:7233

# Server
ROLE_SERVER_PORT=8090
ROLE_SERVER_ENV=local

# OpenTelemetry (optional — defaults to disabled)
# ROLE_OTEL_ENABLED=true
# ROLE_OTEL_ENDPOINT=http://otel-staging.rolds.dev:4318

# SQS notifications (optional — only needed for notification flows)
# ROLE_SQS_REGION=us-east-1
# ROLE_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/<account>/<queue>
